{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "extends": ["../../.oxlintrc.json"],
  "rules": {
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": ["**/db/client", "drizzle-orm", "drizzle-orm/**"],
            "message": "Database access is only allowed inside src/db. Expose a query function from src/db/queries instead."
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": ["src/db/**", "src/lib/auth.ts", "drizzle.config.ts"],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ]
}

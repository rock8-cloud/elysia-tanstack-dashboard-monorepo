# Postgres connection string (docker-compose.yml at the repo root provides this database)
DATABASE_URL=postgres://postgres:postgres@localhost:5434/app

# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# URL this API is reachable at (better-auth base URL)
BETTER_AUTH_URL=http://localhost:3001

# Origin of the web app, allowed for CORS + trusted by better-auth
CORS_ORIGIN=http://localhost:3000

PORT=3001

# Optional: create this account after migrations when the API starts.
# Omit these variables or set SEED_DEFAULT_USER=false to disable seeding.
SEED_DEFAULT_USER=true
SEED_USER_NAME=Demo User
SEED_USER_EMAIL=demo@example.com
SEED_USER_PASSWORD=demo12345

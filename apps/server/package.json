{
  "name": "@repo/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --target bun --outdir dist",
    "start": "bun run dist/index.js",
    "check-types": "tsc --noEmit",
    "lint": "oxlint",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun run src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "auth:generate": "bunx --bun @better-auth/cli@1.6.23 generate --config src/lib/auth.ts --output src/db/schema/auth.ts -y"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.29",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/bun": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "oxlint": "^1.74.0",
    "typescript": "^6.0.2"
  }
}

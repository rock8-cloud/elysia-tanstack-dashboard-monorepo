{
  "name": "elysia-tanstack-dashboard-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Rock8Cloud blueprint for an Elysia API and TanStack Start dashboard monorepo",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "validate": "bun run format:check && bun run lint && bun run check-types && bun run test && bun run build",
    "security:audit": "bun audit --audit-level=high",
    "db:up": "docker compose up -d --wait",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "turbo run db:seed",
    "db:setup": "bun run db:migrate && bun run db:seed",
    "db:studio": "turbo run db:studio"
  },
  "devDependencies": {
    "oxfmt": "^0.59.0",
    "turbo": "^2.10.5",
    "typescript": "^6.0.2"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14"
    }
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "packageManager": "bun@1.3.14"
}
